(cl:defpackage #:mine/term/terminal
  (:use #:coalton #:coalton-prelude)
  (:local-nicknames
   (#:color #:mine/term/color)
   (#:esc #:mine/term/escape)
   (#:screen #:mine/term/screen)
   (#:input #:mine/term/input)
   (#:vec #:coalton/vector)
   (#:cell #:coalton/cell))
  (:export
   #:Terminal
   #:best-effort? #:set-best-effort!
   #:probe-kitty-keyboard
   #:terminal-init #:terminal-shutdown
   #:.terminal-screen
   #:terminal-cols #:terminal-rows #:terminal-update-size!
   #:terminal-flush
   #:terminal-clear-screen
   #:terminal-read-input
   #:terminal-read-input-timeout
   #:terminal-wait-for-key
   #:terminal-pause-input!
   #:terminal-resume-input!
   #:terminal-poll-bytes!
   #:terminal-post-wakeup))

(in-package #:mine/term/terminal)

(cl:eval-when (:compile-toplevel :load-toplevel :execute)
  (cl:require :sb-concurrency))

(cl:defstruct %terminal-input-runtime
  (mailbox   (sb-concurrency:make-mailbox :name "mine-terminal-input") :type cl:t)
  (thread    cl:nil :type cl:t)
  (running-p cl:t :type cl:boolean))

(cl:defvar *terminal-input-mailbox* cl:nil
  "Mailbox for waking the main UI loop from non-terminal threads.")

(cl:defvar *terminal-wakeup-message* (cl:gensym "TERMINAL-WAKEUP-")
  "Internal sentinel used to wake the main UI loop without a terminal event.")

(cl:define-condition %terminal-input-stop () ())

(cl:defun %terminal-post-wakeup ()
  "Wake the main UI loop without adding a user-visible input event."
  (cl:let ((mailbox *terminal-input-mailbox*))
    (cl:when mailbox
      (sb-concurrency:send-message mailbox *terminal-wakeup-message*))))

(cl:defun %terminal-post-resize (cl:&optional (mailbox *terminal-input-mailbox*))
  "Post a resize event using the current terminal dimensions."
  (cl:when mailbox
    (cl:multiple-value-bind (rows cols)
        (mine/bindings/terminal:terminal-get-size)
      (sb-concurrency:send-message
       mailbox
       (mine/term/input:IEvResize cols rows)))))

(cl:defun %terminal-install-resize-handler ()
  #-win32
  (sb-sys:enable-interrupt
   sb-posix:sigwinch
   (cl:lambda (cl:&rest _)
     (cl:declare (cl:ignore _))
     (%terminal-post-resize)))
  #+win32
  cl:nil)

(cl:defun %terminal-input-events (messages)
  (cl:let ((events cl:nil))
    (cl:dolist (message messages (cl:nreverse events))
      (cl:unless (cl:eq message *terminal-wakeup-message*)
        (cl:push message events)))))

(cl:defun %terminal-input-runtime-start (runtime term)
  (cl:let ((thread (%terminal-input-runtime-thread runtime)))
    (cl:when (cl:or (cl:null thread)
                    (cl:not (sb-thread:thread-alive-p thread)))
      (cl:setf (%terminal-input-runtime-running-p runtime) cl:t)
      (cl:setf *terminal-input-mailbox*
               (%terminal-input-runtime-mailbox runtime))
      (cl:setf (%terminal-input-runtime-thread runtime)
               (mine/bindings/thread:make-thread
                "mine-input"
                (cl:lambda ()
                  (cl:handler-case
                      (cl:let ((mailbox (%terminal-input-runtime-mailbox runtime)))
                        (%terminal-install-resize-handler)
                        (cl:loop
                          :while (%terminal-input-runtime-running-p runtime)
                          :do
                          (cl:let ((events (mine/term/terminal::%poll-raw-input! term)))
                            (cl:dolist (event events)
                              (sb-concurrency:send-message mailbox event)))))
                    (%terminal-input-stop () cl:nil)))))))
  (cl:values))

(cl:defun %terminal-input-runtime-stop (runtime)
  (cl:setf (%terminal-input-runtime-running-p runtime) cl:nil)
  (cl:let ((thread (%terminal-input-runtime-thread runtime)))
    (cl:when thread
      (cl:when (sb-thread:thread-alive-p thread)
        (cl:ignore-errors
          (sb-thread:interrupt-thread
           thread
           (cl:lambda ()
             (cl:error '%terminal-input-stop)))))
      (cl:ignore-errors
        (sb-thread:join-thread thread :timeout 0.25d0 :default cl:nil))
      (cl:unless (sb-thread:thread-alive-p thread)
        (cl:setf (%terminal-input-runtime-thread runtime) cl:nil))))
  (cl:when (cl:eq *terminal-input-mailbox*
                  (%terminal-input-runtime-mailbox runtime))
    (cl:setf *terminal-input-mailbox* cl:nil))
  (cl:values))

(cl:defun %terminal-input-runtime-read-batch (runtime)
  (cl:let ((mailbox (%terminal-input-runtime-mailbox runtime)))
    (cl:multiple-value-bind (first ok)
        (sb-concurrency:receive-message mailbox)
      (cl:if ok
             (%terminal-input-events
              (cl:cons first (sb-concurrency:receive-pending-messages mailbox)))
             Nil))))

(cl:defun %terminal-input-runtime-read-batch-timeout (runtime timeout-ms)
  (cl:let ((mailbox (%terminal-input-runtime-mailbox runtime)))
    (cl:if (cl:zerop timeout-ms)
           (%terminal-input-events
            (sb-concurrency:receive-pending-messages mailbox))
           (cl:multiple-value-bind (first ok)
               (sb-concurrency:receive-message
                mailbox
                :timeout (cl:/ timeout-ms 1000))
             (cl:if ok
                    (%terminal-input-events
                     (cl:cons first (sb-concurrency:receive-pending-messages mailbox)))
                    Nil)))))

(cl:defun %terminal-input-runtime-read-one (runtime)
  (cl:let ((mailbox (%terminal-input-runtime-mailbox runtime)))
    (cl:loop
      (cl:multiple-value-bind (message ok)
          (sb-concurrency:receive-message mailbox)
        (cl:when (cl:and ok (cl:not (cl:eq message *terminal-wakeup-message*)))
          (cl:return message))))))

(cl:defun %read-terminal-bytes (timeout-ms)
  "Read available bytes from stdin via the platform layer.
Returns a Coalton-compatible (Vector UFix)."
  (cl:multiple-value-bind (byte-vec count)
      (mine/bindings/terminal:terminal-read-bytes timeout-ms)
    (cl:declare (cl:ignore count))
    (cl:if (cl:and byte-vec (cl:plusp (cl:length byte-vec)))
        ;; Convert (unsigned-byte 8) vector to Coalton (Vector UFix)
        (cl:let* ((len (cl:length byte-vec))
                  (result (cl:make-array len :fill-pointer len
                                             :adjustable cl:t
                                             :element-type cl:t)))
          (cl:dotimes (i len)
            (cl:setf (cl:aref result i) (cl:aref byte-vec i)))
          result)
        ;; No data — empty vector
        (cl:make-array 0 :fill-pointer 0 :adjustable cl:t
                         :element-type cl:t))))

(cl:defun %digit-byte-p (b)
  (cl:and (cl:>= b 48) (cl:<= b 57)))

(cl:defun %primary-device-attributes-response-p (resp)
  "Return T if RESP contains a primary device attributes response."
  (cl:let ((len (cl:length resp)))
    (cl:loop :for i :from 0 :below len
             :when (cl:and (cl:<= (cl:+ i 1) (cl:1- len))
                           (cl:= (cl:aref resp i) 27)
                           (cl:= (cl:aref resp (cl:+ i 1)) 91))
               :do (cl:loop :for j :from (cl:+ i 2) :below len
                            :for b = (cl:aref resp j)
                            :do (cl:cond
                                  ((cl:or (%digit-byte-p b)
                                          (cl:= b 59)
                                          (cl:= b 63))
                                   nil)
                                  ((cl:= b 99)
                                   (cl:return-from %primary-device-attributes-response-p cl:t))
                                  (cl:t
                                   (cl:return)))))
    cl:nil))

(cl:defun %query-progressive-enhancement-flags (resp)
  "Return the queried kitty progressive enhancement flags from RESP.
Returns NIL if no query response is present."
  (cl:let ((len (cl:length resp)))
    (cl:loop :for i :from 0 :below len
             :when (cl:and (cl:<= (cl:+ i 2) (cl:1- len))
                           (cl:= (cl:aref resp i) 27)
                           (cl:= (cl:aref resp (cl:+ i 1)) 91)
                           (cl:= (cl:aref resp (cl:+ i 2)) 63))
               :do (cl:let ((value 0)
                            (saw-digit cl:nil))
                     (cl:loop :for j :from (cl:+ i 3) :below len
                              :for b = (cl:aref resp j)
                              :do (cl:cond
                                    ((%digit-byte-p b)
                                     (cl:setf saw-digit cl:t
                                               value (cl:+ (cl:* value 10)
                                                            (cl:- b 48))))
                                    ((cl:= b 117)
                                     (cl:return-from %query-progressive-enhancement-flags
                                       (cl:if saw-digit value 0)))
                                    (cl:t
                                     (cl:return))))))
    cl:nil))

(cl:defun %version>= (version-str major minor patch)
  "Return T if VERSION-STR (e.g. \"0.21.0\") is >= MAJOR.MINOR.PATCH."
  (cl:ignore-errors
    (cl:let* ((parts (cl:loop :for start = 0 :then (cl:1+ dot)
                              :for dot = (cl:position #\. version-str :start start)
                              :collect (cl:parse-integer
                                        version-str :start start
                                        :end (cl:or dot (cl:length version-str))
                                        :junk-allowed cl:t)
                              :while dot))
              (v-major (cl:or (cl:first parts) 0))
              (v-minor (cl:or (cl:second parts) 0))
              (v-patch (cl:or (cl:third parts) 0)))
      (cl:or (cl:> v-major major)
             (cl:and (cl:= v-major major)
                     (cl:or (cl:> v-minor minor)
                            (cl:and (cl:= v-minor minor)
                                    (cl:>= v-patch patch))))))))

(cl:defun %kitty-too-old-p ()
  "Return T if we're running inside kitty with a version too old for
reliable keyboard protocol support.  Kitty 0.20.0 introduced the
protocol but had a regression that sent incorrect bytes for F1-F4
\(kovidgoyal/kitty#3586, fixed in 0.21.0\)."
  (cl:let ((term-program (sb-ext:posix-getenv "TERM_PROGRAM")))
    (cl:when (cl:and term-program (cl:string-equal term-program "kitty"))
      (cl:let ((version-str (sb-ext:posix-getenv "TERM_PROGRAM_VERSION")))
        (cl:or (cl:null version-str)
               (cl:not (%version>= version-str 0 21 0)))))))

(cl:defun %probe-kitty-keyboard ()
  "Probe whether the terminal supports the kitty keyboard protocol.
Enables disambiguation, queries the active flags, and waits for
primary device attributes as the fence. Returns T only if the query
reply reports that flag 1 is active.
Rejects kitty < 0.21.0 which has broken F1-F4 encoding."
  (cl:when (%kitty-too-old-p)
    (cl:return-from %probe-kitty-keyboard cl:nil))
  (mine/bindings/terminal:terminal-enable-raw-mode)
  (cl:unwind-protect
      (cl:progn
        ;; Request disambiguation, query active flags, then use primary
        ;; device attributes as the fence as recommended by the spec.
        (mine/bindings/terminal:terminal-write-string
         (cl:format cl:nil
                    "~c[>1u~c[?u~c[c"
                    (cl:code-char 27)
                    (cl:code-char 27)
                    (cl:code-char 27)))
        (mine/bindings/terminal:terminal-flush)
        ;; Collect response bytes, stop at the primary DA response or timeout.
        (cl:let ((resp (cl:make-array 0 :fill-pointer 0 :adjustable cl:t
                                       :element-type '(cl:unsigned-byte 8))))
          (cl:dotimes (_ 10)  ; up to 10 x 100ms = 1s
            (cl:multiple-value-bind (bytes count)
                (mine/bindings/terminal:terminal-read-bytes 100)
              (cl:declare (cl:ignore count))
              (cl:when (cl:and bytes (cl:plusp (cl:length bytes)))
                (cl:loop :for b :across bytes
                         :do (cl:vector-push-extend b resp))
                (cl:when (%primary-device-attributes-response-p resp)
                  (cl:return)))))
          (cl:let ((flags (%query-progressive-enhancement-flags resp)))
            (cl:and flags (cl:logtest 1 flags)))))
    (cl:ignore-errors
      (mine/bindings/terminal:terminal-write-string
       (cl:format cl:nil "~c[<u" (cl:code-char 27)))
      (mine/bindings/terminal:terminal-flush))
    (mine/bindings/terminal:terminal-disable-raw-mode)))

(coalton-toplevel

  ;;; Best-effort mode

  (define %best-effort-cell (cell:new False))

  (declare best-effort? (Void -> Boolean))
  (define (best-effort?)
    "True if mine is running in best-effort mode (no kitty keyboard protocol)."
    (cell:read %best-effort-cell))

  (declare set-best-effort! (Void -> Void))
  (define (set-best-effort!)
    "Enable best-effort mode."
    (cell:write! %best-effort-cell True)
    (values))

  ;;; Terminal input runtime

  (repr :native %terminal-input-runtime)
  (define-type TerminalInputRuntime
    "Opaque CL-side runtime state for terminal input mailbox and reader thread.")

  (declare %terminal-input-runtime-new (Void -> TerminalInputRuntime))
  (define (%terminal-input-runtime-new)
    "Create a fresh terminal input runtime."
    (lisp (-> TerminalInputRuntime) ()
      (make-%terminal-input-runtime)))

  (declare terminal-post-wakeup (Void -> Void))
  (define (terminal-post-wakeup)
    "Wake the main UI loop without adding a user-visible input event."
    (lisp (-> Void) ()
      (%terminal-post-wakeup)
      (cl:values)))

  (declare %terminal-current-size (Void -> (Tuple UFix UFix)))
  (define (%terminal-current-size)
    "Return the current terminal size as (cols, rows)."
    (lisp (-> (Tuple UFix UFix)) ()
      (cl:multiple-value-bind (rows cols)
          (mine/bindings/terminal:terminal-get-size)
        (Tuple cols rows))))

  ;;; Terminal

  (define-struct Terminal
    "Top-level terminal handle with screen and running state."
    (terminal-screen screen:Screen)
    (terminal-running (cell:Cell Boolean))
    (terminal-input-runtime TerminalInputRuntime)
    (terminal-input-buf (cell:Cell (Vector UFix)))
    (terminal-cols-cell (cell:Cell UFix))
    (terminal-rows-cell (cell:Cell UFix)))

  ;;; Kitty keyboard protocol probe

  (declare probe-kitty-keyboard (Void -> Boolean))
  (define (probe-kitty-keyboard)
    "Probe whether the terminal supports the kitty keyboard protocol.
Returns True if the terminal responds to the CSI ? u query."
    (lisp (-> Boolean) ()
      (cl:if (%probe-kitty-keyboard) True False)))

  ;;; Init

  (declare terminal-init (Void -> Terminal))
  (define (terminal-init)
    "Initialize the terminal.
Enables raw mode, enters the alternate screen, enables mouse tracking,
queries the terminal size, and returns a new Terminal with a fresh Screen."
    ;; Enable raw mode
    (lisp (-> Void) ()
      (mine/bindings/terminal:terminal-enable-raw-mode)
      (cl:values))
    ;; Enter alt screen, enable mouse, hide cursor
    (let setup = (<> (esc:enter-alt-screen)
                     (<> (esc:enable-mouse-tracking)
                         (<> (esc:enable-bracketed-paste)
                             (<> (esc:enable-keyboard-enhancement)
                                 (esc:cursor-hide))))))
    (lisp (-> Void) (setup)
      (mine/bindings/terminal:terminal-write-string setup)
      (mine/bindings/terminal:terminal-flush)
      (cl:values))
    ;; Get terminal size and create screen
    (match (%terminal-current-size)
      ((Tuple cols rows)
       (let runtime = (%terminal-input-runtime-new))
       (let term = (Terminal (screen:screen-new cols rows)
                             (cell:new True)
                             runtime
                             (cell:new (%make-input-buf))
                             (cell:new cols)
                             (cell:new rows)))
       (%start-input-thread! term)
       term)))

  ;;; Shutdown

  (declare terminal-shutdown (Terminal -> Void))
  (define (terminal-shutdown term)
    "Shut down the terminal.
Disables mouse tracking, leaves the alternate screen, restores the
cursor, and disables raw mode."
    (cell:write! (.terminal-running term) False)
    (let runtime = (.terminal-input-runtime term))
    (lisp (-> Void) (runtime)
      (%terminal-input-runtime-stop runtime)
      (cl:values))
    (let teardown = (<> (esc:disable-keyboard-enhancement)
                        (<> (esc:disable-bracketed-paste)
                            (<> (esc:disable-mouse-tracking)
                                (<> (esc:cursor-show)
                                    (<> (esc:sgr-reset)
                                        (esc:leave-alt-screen)))))))
    (lisp (-> Void) (teardown)
      (mine/bindings/terminal:terminal-write-string teardown)
      (mine/bindings/terminal:terminal-flush)
      (mine/bindings/terminal:terminal-disable-raw-mode)
      (cl:values)))

  ;;; Size accessors

  (declare terminal-cols (Terminal -> UFix))
  (define (terminal-cols term)
    "Get the cached terminal width in columns."
    (cell:read (.terminal-cols-cell term)))

  (declare terminal-rows (Terminal -> UFix))
  (define (terminal-rows term)
    "Get the cached terminal height in rows."
    (cell:read (.terminal-rows-cell term)))

  (declare terminal-update-size! (Terminal -> Void))
  (define (terminal-update-size! term)
    "Re-query the terminal size and update cached values."
    (match (%terminal-current-size)
      ((Tuple cols rows)
       (cell:write! (.terminal-cols-cell term) cols)
       (cell:write! (.terminal-rows-cell term) rows)
       (values))))

  ;;; Flush

  (declare terminal-flush (Terminal -> Void))
  (define (terminal-flush term)
    "Flush the screen to the terminal."
    (screen:screen-flush (.terminal-screen term))
    (values))

  (declare terminal-clear-screen (Terminal -> Void))
  (define (terminal-clear-screen _term)
    "Clear the physical terminal screen."
    (let s = (esc:clear-screen))
    (lisp (-> Void) (s)
      (mine/bindings/terminal:terminal-write-string s)
      (mine/bindings/terminal:terminal-flush)
      (cl:values)))

  ;;; Input reading (via byte reads + input parser)

  (declare %make-input-buf (Void -> (Vector UFix)))
  (define (%make-input-buf)
    "Create a fresh input buffer."
    (vec:new))

  (declare %start-input-thread! (Terminal -> Void))
  (define (%start-input-thread! term)
    "Start the terminal-owned input reader thread."
    (let runtime = (.terminal-input-runtime term))
    (lisp (-> Void) (runtime term)
      (%terminal-input-runtime-start runtime term)
      (cl:values)))

  (declare %poll-raw-input! (Terminal -> (List input:InputEvent)))
  (define (%poll-raw-input! term)
    "Read raw bytes, update the internal remainder buffer, and return parsed input events.
On Windows, use a short polling timeout instead of a blocking read so that
the input thread can observe a shutdown request (running-p = NIL) without
needing another keystroke to unblock ReadFile. Win32 synchronous I/O is
not interruptible by sb-thread:interrupt-thread, so a blocking read would
otherwise hold up sb-ext:exit indefinitely."
    (let prev-buf = (cell:read (.terminal-input-buf term)))
    (let new-bytes = (lisp (-> (Vector UFix)) ()
                      #+win32 (%read-terminal-bytes 100)
                      #-win32 (%read-terminal-bytes cl:nil)))
    (let full-buf = (%concat-bufs prev-buf new-bytes))
    (match (input:parse-input full-buf)
      ((Tuple events remainder)
       (cell:write! (.terminal-input-buf term) remainder)
       events)))

  (declare terminal-read-input (Terminal -> (List input:InputEvent)))
  (define (terminal-read-input term)
    "Read available input from the terminal mailbox.
Block until the first event or internal wakeup, then drain any immediately pending events."
    (let runtime = (.terminal-input-runtime term))
    (lisp (-> (List input:InputEvent)) (runtime)
      (%terminal-input-runtime-read-batch runtime)))

  (declare terminal-read-input-timeout (Terminal * UFix -> (List input:InputEvent)))
  (define (terminal-read-input-timeout term timeout-ms)
    "Read terminal input, waiting up to TIMEOUT-MS for the first event."
    (let runtime = (.terminal-input-runtime term))
    (lisp (-> (List input:InputEvent)) (runtime timeout-ms)
      (%terminal-input-runtime-read-batch-timeout runtime timeout-ms)))

  (declare %concat-bufs ((Vector UFix) * (Vector UFix) -> (Vector UFix)))
  (define (%concat-bufs a b)
    "Concatenate two byte vectors."
    (vec:append a b))

  ;;; Blocking key read (for modal dialogs)

  (declare terminal-wait-for-key (Terminal -> input:InputEvent))
  (define (terminal-wait-for-key term)
    "Block until a key, mouse, paste, or resize event is received."
    (let runtime = (.terminal-input-runtime term))
    (lisp (-> input:InputEvent) (runtime)
      (%terminal-input-runtime-read-one runtime)))

  ;;; Pause/resume the background input runtime so a caller can take
  ;;; exclusive ownership of stdin (e.g. the keyboard debugger pane).

  (declare terminal-pause-input! (Terminal -> Void))
  (define (terminal-pause-input! term)
    "Stop the background input-reader thread so the caller can read raw bytes
directly via TERMINAL-POLL-BYTES!. Pair with TERMINAL-RESUME-INPUT!."
    (let runtime = (.terminal-input-runtime term))
    (lisp (-> Void) (runtime)
      (%terminal-input-runtime-stop runtime)
      (cl:values)))

  (declare terminal-resume-input! (Terminal -> Void))
  (define (terminal-resume-input! term)
    "Restart the background input-reader thread after a TERMINAL-PAUSE-INPUT!."
    (%start-input-thread! term))

  (declare terminal-poll-bytes! (Terminal * UFix -> (Vector UFix)))
  (define (terminal-poll-bytes! term timeout-ms)
    "Read raw bytes directly from stdin with a TIMEOUT-MS wait.
Only valid while the input runtime is paused."
    (let _ = term)
    (lisp (-> (Vector UFix)) (timeout-ms)
      (%read-terminal-bytes timeout-ms))))
